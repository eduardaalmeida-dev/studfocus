# =============================================
# StudyFocus — Configuração de Ambiente
# Copie este arquivo para .env e ajuste os valores
# =============================================

# Ambiente: development | production
APP_ENV=development

# URL base da aplicação (sem barra no final)
APP_URL=http://localhost/studyfocus/public

# ── Banco de Dados ──────────────────────────
DB_HOST=localhost
DB_NAME=studyfocus
DB_USER=root
DB_PASS=

# ── Sessão ──────────────────────────────────
SESSION_LIFETIME=7200   # segundos (2h)

# ── Upload de Arquivos ───────────────────────
UPLOAD_MAX_SIZE=10485760   # bytes (10MB)
UPLOAD_DIR=storage/uploads
